{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Boer-LAN-Server",
  "version": "1.0.9",
  "identifier": "com.boer.lan-server",
  "build": {
    "beforeDevCommand": "npm run dev:stack",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "博尔局域网服务器管理 V1.0.9",
        "width": 1600,
        "height": 1000,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "backend-server*",
      "config/*"
    ]
  }
}
